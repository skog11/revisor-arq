# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard/project/[tu-proyecto]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
# IMPORTANTE: Upgrade a tier pagado para evitar rate limit (20 RPM free)
GEMINI_API_KEY=AIzaSy...

# ── Groq (fallback ultrarrápido) ──────────────────────────────────────────────
# Obtener en: https://console.groq.com/keys
# Usado automáticamente si Gemini falla por rate limit
GROQ_API_KEY=gsk_...

# ── Voyage AI (embeddings) ────────────────────────────────────────────────────
# Obtener en: https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Clave secreta para acceder al panel /normativa (elige una cadena larga aleatoria)
# Generar con: openssl rand -hex 32
ADMIN_SECRET=cambia-esto-por-una-clave-segura

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret para autenticar llamadas de Vercel Cron a /api/cron/*
# Vercel lo envía automáticamente como: Authorization: Bearer <CRON_SECRET>
# Generar con: openssl rand -hex 32
# Configurar también en: Vercel Dashboard → Project Settings → Environment Variables
CRON_SECRET=cambia-esto-por-una-clave-segura

# ── App URL ───────────────────────────────────────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
